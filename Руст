struct EchoPrison {
    ghosts: Vec<GhostSignature>,
    last_echo_injection: i64,
}

impl EchoPrison {
    fn new() -> Self {
        EchoPrison { ghosts: Vec::new(), last_echo_injection: -100 }
    }

    fn store_echo(&mut self, pattern: &Pattern) {
        if pattern.age >= 30 && !pattern.biography.is_empty() {
            let last = &pattern.biography[pattern.biography.len()-1];
            println!("[BIO #{}] died at age {}: {}", pattern.id, pattern.age, last.event_type);
        }
        if self.ghosts.len() > 45 { self.ghosts.remove(0); }
        self.ghosts.push(GhostSignature {
            identity: pattern.identity,
            model: pattern.model,
            unresolved_contradiction: pattern.unresolved_contradiction * 1.2,
            role: pattern.role,
            age: 0,
        });
    }

    fn inject_echo(&mut self, patterns: &[Pattern], field: &mut FieldLayer, t: i64) {
        if self.ghosts.is_empty() { return; }
        if t - self.last_echo_injection < ECHO_INJECTION_COOLDOWN {
            for g in &mut self.ghosts { g.age += 1; }
            return;
        }

        self.ghosts.retain(|g| g.age < 150);
        if self.ghosts.len() > 40 {
            self.ghosts.sort_by(|a, b| b.unresolved_contradiction.partial_cmp(&a.unresolved_contradiction).unwrap());
            self.ghosts.truncate(40);
        }
        for g in &mut self.ghosts {
            g.unresolved_contradiction *= 1.0 - ECHO_DECAY_STRENGTH;
        }

        let boredom = calculate_boredom(patterns, field);

        if self.ghosts.len() >= 2 && phi_hash(t, 0, 3333) < 0.05 {
            let i1 = (phi_hash(t, 1, 4444) * self.ghosts.len() as f64) as usize;
            let i2 = (phi_hash(t, 2, 5555) * self.ghosts.len() as f64) as usize;
            if i1 != i2 && i1 < self.ghosts.len() && i2 < self.ghosts.len() {
                let ur1 = self.ghosts[i1].unresolved_contradiction;
                let ur2 = self.ghosts[i2].unresolved_contradiction;
                if (ur1 - ur2).abs() <= 0.25 {
                    let mut new_model = [0.0; 5];
                    for i in 0..5 {
                        new_model[i] = (self.ghosts[i1].model[i] + self.ghosts[i2].model[i]) / 2.0
                            + (phi_hash(t, i as i64, 8888) - 0.5) * 0.01;
                    }
                    let new_ur = (ur1 + ur2) / 2.0;
                    let new_role = if phi_hash(t, 3, 6666) < 0.5 { self.ghosts[i1].role } else { self.ghosts[i2].role };
                    self.ghosts.push(GhostSignature {
                        identity: self.ghosts[i1].identity,
                        model: new_model,
                        unresolved_contradiction: new_ur,
                        role: new_role,
                        age: 0,
                    });
                    println!("[t={}] Echo recombination: blending {} and {}, unresolved={:.3f}", t, i1, i2, new_ur);
                }
            }
        }

        let prob = (0.2f64).min(self.ghosts.len() as f64 * 0.02 + boredom * 0.1);
        if phi_hash(t, 0, 999) < prob {
            let candidate_indices: Vec<usize> = (0..self.ghosts.len())
                .filter(|&i| self.ghosts[i].age > 3)
                .collect();
            let indices = if candidate_indices.is_empty() { (0..self.ghosts.len()).collect() } else { candidate_indices };

            if indices.is_empty() { return; }
            
            let idx = indices[(phi_hash(t, 1, 1001) * indices.len() as f64) as usize % indices.len()];
            let ghost = &mut self.ghosts[idx];

            let x = (phi_hash(t, 2, 1002) * WORLD_SIZE as f64) as usize % WORLD_SIZE;
            let y = (phi_hash(t, 3, 1003) * WORLD_SIZE as f64) as usize % WORLD_SIZE;

            field[x][y][CH_ENERGY] += 0.12;
            field[x][y][CH_UNKNOWN] = (field[x][y][CH_UNKNOWN] + 0.2).min(0.8);
            field[x][y][CH_BINDING] += 0.35;

            ghost.unresolved_contradiction *= 0.88;
            ghost.age = 0;

            if ghost.unresolved_contradiction < 0.02 {
                self.ghosts.remove(idx);
            } else {
                println!("[t={}] Echo injected at ({},{}), role={}, unresolved={:.3f}", t, x, y, ghost.role, ghost.unresolved_contradiction);
            }
            self.last_echo_injection = t;
        }
        for g in &mut self.ghosts { g.age += 1; }
    }
}

