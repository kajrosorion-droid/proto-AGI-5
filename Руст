#[inline]
fn phi_hash(x: i64, y: i64, seed: i64) -> f64 {
    let xf = x as f64;
    let yf = y as f64;
    let sf = seed as f64;
    ((xf * PHI + yf * PHI * PHI + sf * PHI * PHI * PHI) % 1.0 + 1.0) % 1.0
}

#[inline]
fn phi_noise(t: i64, x: i64, y: i64, seed: i64) -> f64 {
    (phi_hash(t + x, y + t, seed) - 0.5) * 0.1
}

#[inline]
fn squash(x: f64) -> f64 {
    if x.is_nan() || x.is_infinite() { return 0.5; }
    x / (1.0 + x.abs())
}

fn safe_mean(arr: &[f64], default: f64) -> f64 {
    let (sum, count) = arr.iter()
        .filter(|x| x.is_finite())
        .fold((0.0, 0usize), |(s, c), &v| (s + v, c + 1));
    if count == 0 { default } else { sum / count as f64 }
}

fn emotional_decay_factor(age: i32) -> f64 {
    let age_factor = 1.0 - 0.3 * (age as f64 / 200.0).tanh();
    EMOTIONAL_DECAY_RATE_BASE.powf(age_factor)
}

#[inline]
fn clip(val: f64, min_val: f64, max_val: f64) -> f64 {
    val.max(min_val).min(max_val)
}

