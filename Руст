fn calculate_boredom(patterns: &[Pattern], field: &FieldLayer) -> f64 {
    let mut err_history = Vec::new();
    for p in patterns {
        if p.alive && !p.pred_error_history.is_empty() {
            let start = if p.pred_error_history.len() > BOREDOM_WINDOW { p.pred_error_history.len() - BOREDOM_WINDOW } else { 0 };
            err_history.extend_from_slice(&p.pred_error_history[start..]);
        }
    }
    if err_history.is_empty() { return 0.0; }
    let avg_recent_err = err_history.iter().sum::<f64>() / err_history.len() as f64;

    let mut sum_unknown = 0.0;
    for x in 0..WORLD_SIZE { for y in 0..WORLD_SIZE { sum_unknown += field[x][y][CH_UNKNOWN]; } }
    let avg_unknown = sum_unknown / (WORLD_SIZE * WORLD_SIZE) as f64;

    let tensions: Vec<f64> = patterns.iter().filter(|p| p.alive).map(|p| p.cognitive_tension).collect();
    let avg_tension = if tensions.is_empty() { 0.01 } else { tensions.iter().sum::<f64>() / tensions.len() as f64 };

    let mut boredom = 0.0;
    if avg_recent_err < BOREDOM_ERR_THRESHOLD { boredom += 0.4; }
    if avg_unknown < BOREDOM_UNKNOWN_THRESHOLD { boredom += 0.4; }
    if avg_tension < BOREDOM_TENSION_THRESHOLD { boredom += 0.2; }
    boredom
}

fn crisis_injection(field: &mut FieldLayer, t: i64) {
    if t % CRISIS_PERIOD as i64 == 0 && t > 0 {
        let intensity = CRISIS_INTENSITY * (1.0 + 0.5 * (t as f64 * 0.01).sin());
        for x in 0..WORLD_SIZE {
            for y in 0..WORLD_SIZE {
                if phi_hash(x as i64, y as i64, t) < intensity {
                    field[x][y][CH_ENERGY] += (phi_hash(x as i64, y as i64, t + 1) - 0.5) * 0.2;
                    field[x][y][CH_UNKNOWN] = (field[x][y][CH_UNKNOWN] + 0.15).min(0.8);
                    field[x][y][CH_CRISIS] = (field[x][y][CH_CRISIS] + 0.3).min(1.0);
                }
            }
        }
    }
}

fn anti_conformist_injection(patterns: &mut [Pattern], t: i64) {
    if t % ANTI_CONFORMIST_INTERVAL as i64 != 0 || t == 0 { return; }
    let alive: Vec<usize> = (0..patterns.len()).filter(|&i| patterns[i].alive && patterns[i].age >= MIN_AGE_FOR_ANTI_CONFORMIST).collect();
    if alive.is_empty() { return; }

    let idx = alive[(phi_hash(t, 0, 777) * alive.len() as f64) as usize % alive.len()];
    let mutant = &mut patterns[idx];

    mutant.emotional_memory.insert("gratitude".to_string(), 0.1);
    mutant.emotional_memory.insert("grief".to_string(), 0.1);
    mutant.semantic_state = "neutral".to_string();
    mutant.intent = None;
    mutant.intent_commitment = 0.0;
    mutant.goals = vec![Goal {
        goal_type: "explore".to_string(),
        priority: 1.5,
        target: None,
        age: 0,
        persistence: 40,
    }];
    mutant.last_intent_switch_age = mutant.age;
    mutant.log_event("anti_conformist_injected");
    println!("[t={}] ANTI-CONFORMIST: Pattern {} turned explorer (age={})", t, mutant.id, mutant.age);
}

fn process_spores(patterns: &mut Vec<Pattern>, field: &FieldLayer) -> Vec<Pattern> {
    let mut new_patterns = Vec::new();

    for i in 0..patterns.len() {
        if let Some((sx, sy, _)) = patterns[i].pending_spore {
            if field[sx][sy][CH_OWNER] < 0.5 {
                let id = next_id();
                let mut cells = HashSet::new();
                cells.insert((sx, sy));
                let child = Pattern::new(id, cells, Some(&patterns[i]));
                new_patterns.push(child);
            }
            patterns[i].pending_spore = None;
        }
    }
    new_patterns
}

fn resolve_competitions_spatial(patterns: &mut Vec<Pattern>, field: &mut FieldLayer) {
    let n = patterns.len();

    for i in 0..n {
        if !patterns[i].alive { continue; }
        for j in i+1..n {
            if !patterns[j].alive { continue; }

            let overlap: bool = patterns[i].cells.iter().any(|c| patterns[j].cells.contains(c));
            if overlap {
                let (left, right) = patterns.split_at_mut(j);
                left[i].compete(&mut right[0], field);
            }
        }
    }
}

fn field_dynamics(field: &mut FieldLayer, scar: &mut ScarField, t: i64) {
    let mut new_energy = vec![vec![0.0f64; WORLD_SIZE]; WORLD_SIZE];
    for x in 0..WORLD_SIZE {
        for y in 0..WORLD_SIZE {
            let mut sum = field[x][y][CH_ENERGY] * 4.0;
            for (dx, dy) in &[(-1i32, 0i32), (1, 0), (0, -1), (0, 1)] {
                let nx = ((x as i32 + dx + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                let ny = ((y as i32 + dy + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                sum += field[nx][ny][CH_ENERGY];
            }
            new_energy[x][y] = sum / 8.0;
        }
    }

    for x in 0..WORLD_SIZE {
        for y in 0..WORLD_SIZE {
            scar[x][y] *= FIELD_DECAY;
            field[x][y][CH_SCAR] = scar[x][y].min(SCAR_SATURATION);
            field[x][y][CH_ENERGY] = new_energy[x][y];
            field[x][y][CH_ENERGY] += HEARTBEAT_AMPLITUDE * (t as f64 * HEARTBEAT_FREQ + field[x][y][CH_VORTICITY]).sin();
            field[x][y][CH_ENERGY] += SCAR_ENERGY_COUPLING * field[x][y][CH_SCAR];
            field[x][y][CH_ENERGY] += VORTICITY_COUPLING * field[x][y][CH_VORTICITY];
        }
    }
}

fn collect_metrics(patterns: &[Pattern], field: &FieldLayer, t: i64) -> String {
    let alive: Vec<&Pattern> = patterns.iter().filter(|p| p.alive).collect();
    if alive.is_empty() { return format!("[t={}] NO PATTERNS ALIVE", t); }

    let err = alive.iter().map(|p| p.pred_error).sum::<f64>() / alive.len() as f64;
    let soul = alive.iter().map(|p| p.soul_weight).sum::<f64>() / alive.len() as f64;
    let lineages: HashSet<u32> = alive.iter().map(|p| p.lineage_id).collect();

    let mut binding_sum = 0.0;
    for x in 0..WORLD_SIZE { for y in 0..WORLD_SIZE { binding_sum += field[x][y][CH_BINDING]; } }
    let binding = binding_sum / (WORLD_SIZE * WORLD_SIZE) as f64;

    let mut states: HashMap<String, usize> = HashMap::new();
    for p in &alive {
        *states.entry(p.semantic_state.clone()).or_insert(0) += 1;
    }

    let mut intents: HashMap<String, usize> = HashMap::new();
    for p in &alive {
        if let Some(intent) = &p.intent {
            *intents.entry(intent.goal_type.clone()).or_insert(0) += 1;
        }
    }

    let epi_scar = alive.iter().map(|p| p.epistemic_scar).sum::<f64>() / alive.len() as f64;

    format!("[t={}] patterns={} lineages={} err={:.3f} soul={:.3f} binding={:.3f} states={:?} intents={:?} epi_scar={:.3f}",
        t, alive.len(), lineages.len(), err, soul, binding, states, intents, epi_scar)
}

fn detect_new_components(field: &FieldLayer) -> Vec<HashSet<(usize, usize)>> {
    let mut visited = vec![vec![false; WORLD_SIZE]; WORLD_SIZE];
    let mut components = Vec::new();

    for x in 0..WORLD_SIZE {
        for y in 0..WORLD_SIZE {
            if !visited[x][y] && field[x][y][CH_ENERGY] > PATTERN_ENERGY_THRESHOLD && field[x][y][CH_OWNER] < 0.5 {
                let mut component = HashSet::new();
                let mut stack = vec![(x, y)];
                visited[x][y] = true;

                while let Some((cx, cy)) = stack.pop() {
                    component.insert((cx, cy));
                    for (dx, dy) in &[(-1i32, 0i32), (1, 0), (0, -1), (0, 1)] {
                        let nx = ((cx as i32 + dx + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                        let ny = ((cy as i32 + dy + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                        if !visited[nx][ny] && field[nx][ny][CH_ENERGY] > PATTERN_ENERGY_THRESHOLD && field[nx][ny][CH_OWNER] < 0.5 {
                            visited[nx][ny] = true;
                            stack.push((nx, ny));
                        }
                    }
                }

                if component.len() >= MIN_COMPONENT_CELLS {
                    components.push(component);
                }
            }
        }
    }
    components
}

fn match_patterns(new_components: Vec<HashSet<(usize, usize)>>, patterns: &mut Vec<Pattern>, field: &mut FieldLayer) {
    for cells in new_components {
        let id = next_id();
        let mut p = Pattern::new(id, cells, None);
        p.update_properties(field);
        let dummy_scar = vec![vec![0.0; WORLD_SIZE]; WORLD_SIZE];
        p.update_model(field, None, None, &dummy_scar);
        patterns.push(p);
    }
}

fn emergency_rescue(patterns: &mut Vec<Pattern>, field: &mut FieldLayer, t: i64, last_rescue_t: &mut i64) {
    let alive_count = patterns.iter().filter(|p| p.alive).count();
    if alive_count >= MIN_POPULATION_FOR_SPAWN { return; }
    if t - *last_rescue_t < 30 { return; }
    *last_rescue_t = t;

    let num_rescue = (MIN_PATTERNS_GUARANTEED - alive_count).max(5);
    let donor = patterns.iter().find(|p| p.alive);

    for i in 0..num_rescue {
        let x = (phi_hash(t, i as i64, 999) * WORLD_SIZE as f64) as usize % WORLD_SIZE;
        let y = (phi_hash(t, i as i64, 1000) * WORLD_SIZE as f64) as usize % WORLD_SIZE;
        field[x][y][CH_ENERGY] += 0.2;
        field[x][y][CH_UNKNOWN] += 0.1;
        field[x][y][CH_OWNER] = 0.0;

        let id = next_id();
        let mut cells = HashSet::new();
        cells.insert((x, y));
        let mut p = Pattern::new(id, cells, donor);
        if let Some(d) = donor {
            for j in 0..5 {
                p.belief[j] = d.belief[j] + (phi_hash(id as i64, j as i64, 99) - 0.5) * 0.1;
            }
        }
        p.update_properties(field);
        patterns.push(p);
    }
    println!("[t={}] EMERGENCY RESCUE: spawned {} patterns", t, num_rescue);
}

