fn init_field() -> FieldLayer {
    let mut f = vec![vec![vec![0.0; CHANNELS]; WORLD_SIZE]; WORLD_SIZE];
    for x in 0..WORLD_SIZE {
        for y in 0..WORLD_SIZE {
            f[x][y][CH_ENERGY] = phi_hash(x as i64, y as i64, 1) * 0.2 - 0.1;
            f[x][y][CH_FLUX] = phi_hash(x as i64, y as i64, 2) * 0.1;
            f[x][y][CH_VORTICITY] = phi_hash(x as i64, y as i64, 3) * 0.1 - 0.05;
            f[x][y][CH_UNKNOWN] = UNKNOWN_BACKGROUND;
            f[x][y][CH_BINDING] = 0.05;
            f[x][y][CH_ENERGY] += phi_noise(0, x as i64, y as i64, 42) * 0.3;
        }
    }
    f
}

