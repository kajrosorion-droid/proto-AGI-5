impl Pattern {
    fn new(id: u32, cells: HashSet<(usize, usize)>, parent: Option<&Pattern>) -> Self {
        let parent_id = parent.map(|p| p.id).unwrap_or(0);
        let lineage_id = parent.map(|p| p.lineage_id).unwrap_or(id);
        let generation = parent.map(|p| p.generation + 1).unwrap_or(0);
        let lineage_age = parent.map(|p| p.lineage_age + 1).unwrap_or(0);

        let identity = {
            let mut arr = [0.0; 8];
            for i in 0..8 { arr[i] = phi_hash(id as i64, i as i64, 100); }
            arr
        };

        let (belief, prediction, model, self_model, unknown_belief, unknown_model) = if let Some(p) = parent {
            let mut m = p.model;
            for i in 0..5 { m[i] += MUTATION_STRENGTH_BASE * (phi_hash(id as i64, i as i64, 100) - 0.5); }
            (p.belief, p.prediction, m, p.self_model, p.unknown_belief, p.unknown_model)
        } else {
            let mut m = [0.0; 5];
            for i in 0..5 { m[i] = 0.1 * (phi_hash(id as i64, i as i64, 1) - 0.5); }
            ([0.0; 5], [0.0; 5], m,
             [0.1 * (phi_hash(id as i64, 101, 1) - 0.5), 0.1 * (phi_hash(id as i64, 102, 1) - 0.5)],
             0.0, 0.1 * (phi_hash(id as i64, 99, 1) - 0.5))
        };

        let role = if let Some(p) = parent {
            if phi_hash(id as i64, 888, 0) < 0.2 { (p.role + 1) % 2 } else { p.role }
        } else {
            if phi_hash(id as i64, 777, 0) < 0.5 { 0 } else { 1 }
        };

        let mut emotional_memory = HashMap::new();
        if let Some(p) = parent {
            emotional_memory.insert("gratitude".to_string(), p.emotional_memory.get("gratitude").unwrap_or(&0.0) * 0.9);
            emotional_memory.insert("grief".to_string(), p.emotional_memory.get("grief").unwrap_or(&0.0) * 0.9);
        } else {
            emotional_memory.insert("gratitude".to_string(), 0.0);
            emotional_memory.insert("grief".to_string(), 0.0);
        }

        let crisis_memory = if let Some(p) = parent {
            (p.crisis_memory * 0.8).min(CRISIS_MEMORY_MAX)
        } else { 0.0 };

        let pred_error_history = if let Some(p) = parent {
            let mut h = p.pred_error_history.clone();
            if h.len() > 10 { h = h[h.len()-10..].to_vec(); }
            h
        } else { Vec::new() };

        let genome = if let Some(p) = parent {
            let mut g = p.genome.clone();
            let mutations = [
                MUTATION_STRENGTH_BASE * (phi_hash(id as i64, 11, 2) - 0.5),
                MUTATION_STRENGTH_BASE * (phi_hash(id as i64, 12, 2) - 0.5),
                MUTATION_STRENGTH_BASE * (phi_hash(id as i64, 13, 2) - 0.5),
                MUTATION_STRENGTH_BASE * (phi_hash(id as i64, 14, 2) - 0.5),
                MUTATION_STRENGTH_BASE * (phi_hash(id as i64, 15, 2) - 0.5),
            ];
            g.learning_rate = clip(g.learning_rate + mutations[0], 0.5, 2.0);
            g.meta_learning_rate = clip(g.meta_learning_rate + mutations[1], 0.5, 2.0);
            g.metabolic_cost = clip(g.metabolic_cost + mutations[2], 0.5, 2.0);
            g.mobility = clip(g.mobility + mutations[3], 0.5, 2.0);
            g.epistemic_strategy = clip(g.epistemic_strategy + mutations[4], 0.5, 2.0);
            g
        } else {
            Genome {
                learning_rate: MODEL_LEARNING_RATE * (0.8 + 0.4 * phi_hash(id as i64, 1, 3)),
                meta_learning_rate: MODEL_LEARNING_RATE * 0.5 * (0.8 + 0.4 * phi_hash(id as i64, 2, 3)),
                metabolic_cost: 0.005 + 0.005 * phi_hash(id as i64, 3, 4),
                mobility: 0.1 + 0.05 * phi_hash(id as i64, 4, 5),
                epistemic_strategy: phi_hash(id as i64, 5, 6),
            }
        };

        let mut bio = Vec::new();
        bio.push(BioEvent { t: 0, event_type: "birth".to_string(), details: HashMap::new() });

        Pattern {
            id, cells, energy: 0.3, vorticity: 0.0, age: 0, alive: true,
            parent_id, lineage_id, generation, lineage_age,
            identity, belief, prediction, model,
            self_state_prediction: [0.0; 2], self_model, self_surprise: MIN_ACTIVE,
            spirit_gap: 0.0,
            soul_weight: parent.map(|p| p.soul_weight * 0.9).unwrap_or(0.5),
            soul_momentum: 0.0,
            body_memory: parent.map(|p| p.body_memory * 0.95).unwrap_or(0.0),
            unresolved_contradiction: parent.map(|p| p.unresolved_contradiction * 0.9).unwrap_or(0.1),
            role, unknown_belief, unknown_model, unknown_prediction: 0.0,
            epistemic_load: 0.0, prev_epistemic_load: 0.0, crisis_memory,
            memory_trace: Vec::new(), self_consistency: 0.0, coherence: 1.0,
            confidence: 0.0, given_trigger: false, given_count: 0, given_cooldown: 0,
            surprise_signal: 0.0, emotional_memory,
            semantic_state: "neutral".to_string(), in_scream: false,
            local_phase: "MODEL".to_string(),
            dream_timer: (phi_hash(id as i64, 0, 777) * 30.0) as i32 + 30,
            dream_interval: (phi_hash(id as i64, 1, 777) * 40.0) as i32 + 40,
            dream_duration: 3, in_dream: false, dream_progress: 0, scar_dream: 0.0,
            pending_spore: None,
            last_speciation_age: -(SPEACIATION_COOLDOWN * 2),
            biography: bio,
            world_state: [0.0; 8], world_model: [[0.0; 8]; 4], last_action: 0,
            goals: Vec::new(), intent: None, intent_age: 0, intent_commitment: 0.0,
            concepts: HashMap::new(), concept_history: Vec::new(),
            epistemic_scar: 0.0, alarm_level: 0.0,
            last_intent_switch_age: -INTENT_SWITCH_COOLDOWN,
            protection_level: 1.0,
            pred_error: MIN_ACTIVE, pred_error_history,
            unknown_error: 0.0, compression: 0.0, fitness: 0.0,
            error_trend: 0.0, cognitive_tension: MIN_ACTIVE, genome,
        }
    }

    fn log_event(&mut self, event_type: &str) {
        self.biography.push(BioEvent { t: self.age, event_type: event_type.to_string(), details: HashMap::new() });
        if self.biography.len() > 10 { self.biography.remove(0); }
    }

    fn update_properties(&mut self, field: &FieldLayer) {
        if self.cells.is_empty() { self.alive = false; return; }
        let energies: Vec<f64> = self.cells.iter().map(|(x, y)| field[*x][*y][CH_ENERGY]).collect();
        self.energy = safe_mean(&energies, 0.1);
        let vort: Vec<f64> = self.cells.iter().map(|(x, y)| field[*x][*y][CH_VORTICITY]).collect();
        self.vorticity = safe_mean(&vort, 0.0);
    }

    fn generate_goals(&mut self, field: &FieldLayer) {
        let mut new_goals: Vec<Goal> = Vec::new();

        if self.epistemic_load > 0.3 {
            let mut high_unknown = Vec::new();
            for x in 0..WORLD_SIZE {
                for y in 0..WORLD_SIZE {
                    if field[x][y][CH_UNKNOWN] > 0.3 {
                        high_unknown.push((x, y));
                    }
                }
            }
            if !high_unknown.is_empty() {
                let idx = (phi_hash(self.id as i64, self.age as i64, 222) * high_unknown.len() as f64) as usize % high_unknown.len();
                new_goals.push(Goal {
                    goal_type: "explore".to_string(),
                    priority: self.epistemic_load,
                    target: Some(high_unknown[idx]),
                    age: 0,
                    persistence: 50,
                });
            }
        }

        let grat = *self.emotional_memory.get("gratitude").unwrap_or(&0.0);
        let grief = *self.emotional_memory.get("grief").unwrap_or(&0.0);

        if grief > 0.4 {
            new_goals.push(Goal {
                goal_type: "seek_help".to_string(),
                priority: grief,
                target: None,
                age: 0,
                persistence: 30,
            });
        }

        if grat > 0.5 && self.coherence > 0.7 {
            new_goals.push(Goal {
                goal_type: "cooperate".to_string(),
                priority: grat,
                target: None,
                age: 0,
                persistence: 40,
            });
        }

        if grat > 0.8 && self.coherence > 0.6 {
            let priority = 1.2 + 0.3 * (grat - 0.8);
            new_goals.push(Goal {
                goal_type: "explore".to_string(),
                priority,
                target: None,
                age: 0,
                persistence: 20,
            });
        }

        if grief > 0.7 && self.soul_weight < 0.4 {
            new_goals.push(Goal {
                goal_type: "explore".to_string(),
                priority: 1.1,
                target: None,
                age: 0,
                persistence: 15,
            });
        }

        self.goals.retain(|g| g.age < g.persistence);
        for g in &mut self.goals { g.age += 1; }

        let existing_types: HashSet<String> = self.goals.iter().map(|g| g.goal_type.clone()).collect();
        for goal in new_goals {
            if !existing_types.contains(&goal.goal_type) {
                self.goals.push(goal);
            }
        }
    }

    fn update_intent(&mut self) {
        if self.goals.is_empty() {
            self.intent = None;
            self.intent_commitment *= INTENT_COMMITMENT_DECAY;
            return;
        }

        self.goals.sort_by(|a, b| b.priority.partial_cmp(&a.priority).unwrap());
        let best = &self.goals[0];

        if self.intent.is_none() {
            if self.age - self.last_intent_switch_age >= INTENT_SWITCH_COOLDOWN {
                self.intent = Some(best.clone());
                self.intent_commitment = best.priority;
                self.last_intent_switch_age = self.age;
                self.log_event("intent_switch");
            }
        } else {
            self.intent_commitment = 0.9 * self.intent_commitment + 0.1 * best.priority;
            if best.priority > self.intent_commitment * 1.5
                && self.age - self.last_intent_switch_age >= INTENT_SWITCH_COOLDOWN
            {
                self.intent = Some(best.clone());
                self.last_intent_switch_age = self.age;
                self.log_event("intent_switch");
            }
        }
    }

    fn apply_intent_actions(&self, field: &mut FieldLayer) {
        if let Some(intent) = &self.intent {
            match intent.goal_type.as_str() {
                "explore" => {
                    for (x, y) in &self.cells {
                        field[*x][*y][CH_SIGNAL_INVITATION] = (field[*x][*y][CH_SIGNAL_INVITATION] + 0.1).min(1.0);
                        field[*x][*y][CH_INTENT_EXPLORE] = (field[*x][*y][CH_INTENT_EXPLORE] + 0.2).min(1.0);
                    }
                }
                "seek_help" => {
                    for (x, y) in &self.cells {
                        field[*x][*y][CH_SIGNAL_INVITATION] = (field[*x][*y][CH_SIGNAL_INVITATION] + 0.25).min(1.0);
                        field[*x][*y][CH_SIGNAL_GRIEF] = (field[*x][*y][CH_SIGNAL_GRIEF] + 0.1).min(1.0);
                        field[*x][*y][CH_INTENT_SEEK_HELP] = (field[*x][*y][CH_INTENT_SEEK_HELP] + 0.3).min(1.0);
                    }
                }
                "cooperate" => {
                    for (x, y) in &self.cells {
                        field[*x][*y][CH_BINDING] = (field[*x][*y][CH_BINDING] + 0.15).min(1.0);
                        field[*x][*y][CH_SIGNAL_GRATITUDE] = (field[*x][*y][CH_SIGNAL_GRATITUDE] + 0.1).min(1.0);
                        field[*x][*y][CH_INTENT_COOPERATE] = (field[*x][*y][CH_INTENT_COOPERATE] + 0.3).min(1.0);
                    }
                }
                _ => {}
            }
        }
    }

    fn update_phase(&mut self, field: &FieldLayer) {
        let mut sum_unknown = 0.0;
        for x in 0..WORLD_SIZE {
            for y in 0..WORLD_SIZE {
                sum_unknown += field[x][y][CH_UNKNOWN];
            }
        }
        let avg_unknown = sum_unknown / (WORLD_SIZE * WORLD_SIZE) as f64;

        self.local_phase = if self.in_dream {
            "DREAM".to_string()
        } else if self.crisis_memory > 0.5 && self.soul_weight < 0.4 {
            "CRISIS".to_string()
        } else if self.pred_error < 0.05 && self.coherence > 0.9 {
            "COMPRESS".to_string()
        } else if avg_unknown > 0.4 {
            "EXPLORE".to_string()
        } else if self.cognitive_tension < 0.01 {
            "SILENCE".to_string()
        } else {
            "MODEL".to_string()
        };
    }

    fn update_semantic_state(&mut self, field: &FieldLayer) {
        let grat = *self.emotional_memory.get("gratitude").unwrap_or(&0.0);
        let grief = *self.emotional_memory.get("grief").unwrap_or(&0.0);
        let mut warn = 0.0;
        let mut inv = 0.0;
        let mut alarm = 0.0;
        let mut curios = 0.0;

        for (x, y) in &self.cells {
            warn = warn.max(field[*x][*y][CH_SIGNAL_WARNING]);
            inv = inv.max(field[*x][*y][CH_SIGNAL_INVITATION]);
            alarm = alarm.max(field[*x][*y][CH_SIGNAL_ALARM]);
            curios = curios.max(field[*x][*y][CH_SIGNAL_CURIOSITY]);
        }

        self.semantic_state = if self.in_dream {
            "dreaming".to_string()
        } else if grat > 0.15 && warn > 0.05 {
            "grateful_but_cautious".to_string()
        } else if grief > 0.15 && inv > 0.05 {
            "seeking_comfort".to_string()
        } else if alarm > 0.15 && curios > 0.05 {
            "exploring_danger".to_string()
        } else if grat > 0.15 && self.cognitive_tension < 0.25 {
            "contentment".to_string()
        } else if self.in_scream {
            "screaming".to_string()
        } else {
            "neutral".to_string()
        };
    }

    fn update_dream(&mut self, field: &FieldLayer) {
        if self.in_dream {
            self.dream_progress += 1;
            if self.dream_progress >= self.dream_duration {
                self.in_dream = false;
                self.dream_progress = 0;
                self.dream_timer = 0;
                self.dream_interval = (phi_hash(self.id as i64, self.age as i64, 888) * 40.0) as i32 + 40;
                self.log_event("dream_exit");
                if self.soul_weight > 0.6 && self.coherence > 0.9 && phi_hash(self.id as i64, self.age as i64, 999) < 0.2 {
                    for x in 0..WORLD_SIZE {
                        for y in 0..WORLD_SIZE {
                            if field[x][y][CH_OWNER] < 0.5 && field[x][y][CH_ENERGY] > 0.05 {
                                self.pending_spore = Some((x, y, self.scar_dream * 0.5));
                                self.log_event("spore_emitted");
                                break;
                            }
                        }
                        if self.pending_spore.is_some() { break; }
                    }
                }
            }
        } else {
            self.dream_timer += 1;
            if self.dream_timer >= self.dream_interval && self.soul_weight > 0.3 && self.local_phase != "CRISIS" {
                self.in_dream = true;
                self.dream_progress = 0;
                self.log_event("dream_enter");
            }
        }
    }

    fn apply_given_operator(&mut self, field: &mut FieldLayer) {
        self.log_event("given_triggered");
        self.pred_error = (self.pred_error + 0.2).min(MAX_METRIC);
        self.confidence = 1.0 / (1.0 + self.pred_error);
        self.given_count += 1;
        self.given_trigger = true;
        self.given_cooldown = GIVEN_COOLDOWN;
        self.crisis_memory = (self.crisis_memory + 0.1).min(CRISIS_MEMORY_MAX);
        self.body_memory += 0.05;
        for (x, y) in &self.cells {
            field[*x][*y][CH_UNKNOWN] = (field[*x][*y][CH_UNKNOWN] + 0.15).min(0.8);
            field[*x][*y][CH_CRISIS] = (field[*x][*y][CH_CRISIS] + 0.1).min(1.0);
            field[*x][*y][CH_BINDING] = (field[*x][*y][CH_BINDING] + 0.25).min(1.0);
        }
    }

    fn apply_scream(&mut self, field: &mut FieldLayer) {
        if !self.in_scream {
            self.log_event("scream_enter");
            self.in_scream = true;
            self.soul_weight = (self.soul_weight - 0.2).max(0.05);
            self.unresolved_contradiction = (self.unresolved_contradiction + 0.3).min(1.0);
            self.crisis_memory = (self.crisis_memory + 0.15).min(CRISIS_MEMORY_MAX);
            for (x, y) in &self.cells {
                field[*x][*y][CH_SCAR] = (field[*x][*y][CH_SCAR] + SCREAM_SCAR_IMPACT).min(1.0);
                field[*x][*y][CH_BINDING] = (field[*x][*y][CH_BINDING] + SCREAM_BINDING_BOOST).min(1.0);
                field[*x][*y][CH_ENERGY] = (field[*x][*y][CH_ENERGY] - SCREAM_ENERGY_PENALTY).max(-0.2);
                field[*x][*y][CH_CRISIS] = (field[*x][*y][CH_CRISIS] + 0.3).min(1.0);
            }
        }
    }

    fn update_model(&mut self, field: &mut FieldLayer, lineage_counts: Option<&HashMap<u32, usize>>, given_counter: Option<&mut usize>, scar: &ScarField) {
        if self.cells.is_empty() { return; }
        if self.model.iter().any(|x| x.is_nan() || x.is_infinite()) {
            self.model = [0.0; 5];
            self.prediction = [0.0; 5];
            self.belief = [0.0; 5];
        }

        for i in 0..5 {
            self.belief[i] += (phi_hash(self.id as i64, self.age as i64, 8000 + i as i64) - 0.5) * 0.001;
        }

        if self.in_dream {
            self.update_dream(field);
            self.pred_error = (self.pred_error * METRIC_DECAY).max(MIN_ACTIVE);
            return;
        }

        let mut avg_real = [0.0; 5];
        let mut avg_unknown = 0.0;
        let mut avg_crisis_mem = 0.0;
        let mut avg_binding = 0.0;
        let mut local_gratitude = 0.0;
        let mut local_grief = 0.0;
        let mut neighbor_gratitude = 0.0;
        let mut neighbor_grief = 0.0;
        let mut neighbor_count = 0;
        let n = self.cells.len() as f64;

        for (x, y) in &self.cells {
            let strategy = self.genome.epistemic_strategy;
            let crisis_factor = 1.0 + field[*x][*y][CH_CRISIS].min(1.0) * 0.5;
            let noise_factor = if strategy < 0.33 {
                1.0
            } else if strategy < 0.66 {
                1.0 + field[*x][*y][CH_UNKNOWN].min(0.8) * (1.0 - self.unknown_model)
            } else {
                1.0 + field[*x][*y][CH_UNKNOWN].min(0.8) * 1.5
            };

            for i in 0..5 {
                avg_real[i] += field[*x][*y][i].min(10.0).max(-10.0) * noise_factor * crisis_factor;
            }
            avg_unknown += field[*x][*y][CH_UNKNOWN].min(0.8);
            avg_crisis_mem += field[*x][*y][CH_CRISIS].min(1.0);
            avg_binding += field[*x][*y][CH_BINDING].min(1.0);
            local_gratitude += field[*x][*y][CH_SIGNAL_GRATITUDE];
            local_grief += field[*x][*y][CH_SIGNAL_GRIEF];

            for (dx, dy) in &[(-1i32,0i32),(1,0),(0,-1),(0,1)] {
                let nx = ((*x as i32 + dx + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                let ny = ((*y as i32 + dy + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                if field[nx][ny][CH_OWNER] > 0.5 {
                    neighbor_gratitude += field[nx][ny][CH_SIGNAL_GRATITUDE];
                    neighbor_grief += field[nx][ny][CH_SIGNAL_GRIEF];
                    neighbor_count += 1;
                }
            }
        }

        for i in 0..5 { avg_real[i] /= n; }
        avg_unknown /= n;
        avg_crisis_mem /= n;
        avg_binding /= n;
        local_gratitude = (local_gratitude / n).min(0.5);
        local_grief /= n;

        let current_grat = *self.emotional_memory.get("gratitude").unwrap_or(&0.0);
        let current_grief = *self.emotional_memory.get("grief").unwrap_or(&0.0);
        self.emotional_memory.insert("gratitude".to_string(),
            EMOTIONAL_MEMORY_DECAY * current_grat + (1.0 - EMOTIONAL_MEMORY_DECAY) * local_gratitude);
        self.emotional_memory.insert("grief".to_string(),
            EMOTIONAL_MEMORY_DECAY * current_grief + (1.0 - EMOTIONAL_MEMORY_DECAY) * local_grief);

        if neighbor_count > 0 {
            neighbor_gratitude /= neighbor_count as f64;
            neighbor_grief /= neighbor_count as f64;
            let current_grat = *self.emotional_memory.get("gratitude").unwrap_or(&0.0);
            let current_grief = *self.emotional_memory.get("grief").unwrap_or(&0.0);
            self.emotional_memory.insert("gratitude".to_string(),
                EMOTIONAL_INDIVIDUALITY * current_grat + (1.0 - EMOTIONAL_INDIVIDUALITY) * neighbor_gratitude);
            self.emotional_memory.insert("grief".to_string(),
                EMOTIONAL_INDIVIDUALITY * current_grief + (1.0 - EMOTIONAL_INDIVIDUALITY) * neighbor_grief);
        }

        let dec = emotional_decay_factor(self.age);
        let grat = clip(*self.emotional_memory.get("gratitude").unwrap_or(&0.0) * dec, 0.0, 1.0);
        let grief = clip(*self.emotional_memory.get("grief").unwrap_or(&0.0) * dec, 0.0, 1.0);
        self.emotional_memory.insert("gratitude".to_string(), grat);
        self.emotional_memory.insert("grief".to_string(), grief);

        self.crisis_memory = (CRISIS_MEMORY_DECAY * self.crisis_memory + (1.0 - CRISIS_MEMORY_DECAY) * avg_crisis_mem).min(CRISIS_MEMORY_MAX);
        self.epistemic_load = avg_unknown;

        let error: [f64; 5] = {
            let mut e = [0.0; 5];
            for i in 0..5 { e[i] = (avg_real[i] - self.prediction[i]).min(10.0).max(-10.0); }
            e
        };
        let current_error = error.iter().map(|x| x * x).sum::<f64>() / 5.0;

        let raw_pred_error = PRED_ERROR_LEARNING * self.pred_error + 0.1 * current_error + SELF_SURPRISE_FACTOR * self.self_surprise;
        let noise_val = (phi_hash(self.id as i64, (self.age + 500) as i64, 500) - 0.5) * BASE_NOISE * 2.0;
        self.pred_error = clip(squash(raw_pred_error) + noise_val, MIN_ACTIVE, MAX_METRIC);

        for i in 0..5 {
            self.belief[i] = clip(self.belief[i] + 0.05 * error[i], -10.0, 10.0);
            self.prediction[i] = clip(self.belief[i] + self.model[i], -10.0, 10.0);
            self.model[i] = clip(self.model[i] + self.genome.learning_rate * error[i], -10.0, 10.0);
        }

        self.self_consistency = {
            let mut sum = 0.0;
            for i in 0..5 { let d = self.prediction[i] - self.belief[i]; sum += d * d; }
            sum.sqrt()
        };
        self.coherence = 1.0 / (1.0 + self.self_consistency);
        self.confidence = squash(1.0 / (1.0 + self.pred_error));

        if self.coherence > ANTI_COHERENCE_THRESHOLD && phi_hash(self.id as i64, self.age as i64, 9999) < 0.1 {
            for i in 0..5 {
                self.belief[i] += (phi_hash(self.id as i64, self.age as i64, 8888 + i as i64) - 0.5) * ANTI_COHERENCE_SHAKE;
            }
        }

        if self.given_cooldown > 0 {
            self.given_cooldown -= 1;
            self.given_trigger = false;
        } else {
            let given_allowed = given_counter.as_ref().map(|c| **c < MAX_GIVEN_PER_STEP).unwrap_or(true);
            if given_allowed && self.age >= GIVEN_MIN_AGE && self.confidence > GIVEN_CONFIDENCE_THRESHOLD && self.given_cooldown <= 0 {
                self.apply_given_operator(field);
                if let Some(c) = given_counter { **c += 1; }
            }
        }

        let raw_tension = self.pred_error + 0.1 * self.self_surprise + 0.1 * self.self_consistency;
        let noise_tension = (phi_hash(self.id as i64, (self.age + 700) as i64, 700) - 0.5) * BASE_NOISE * 2.0;
        self.cognitive_tension = clip(squash(raw_tension) + noise_tension, MIN_ACTIVE, MAX_METRIC);

        let error_penalty = 1.0 / (1.0 + self.pred_error * 5.0);
        let target_soul = clip(error_penalty * (0.5 + self.coherence * 0.5 - self.unresolved_contradiction * 0.3), 0.0, 1.0);
        self.soul_weight = clip((1.0 - SOUL_WEIGHT_GAIN_RATE) * self.soul_weight + SOUL_WEIGHT_GAIN_RATE * target_soul, 0.0, 1.0);

        self.fitness = 1.0 / (1.0 + self.pred_error) + 0.5 * (0.0f64).max(-self.error_trend) + 0.2 * self.coherence - 0.1 * self.body_memory;
        self.fitness += GRATITUDE_COOPERATION_BONUS * local_gratitude;

        if self.crisis_memory > SCREAM_CRISIS_THRESHOLD && self.soul_weight < SCREAM_SOUL_THRESHOLD && phi_hash(self.id as i64, self.age as i64, 111) < SCREAM_PROB {
            self.apply_scream(field);
        }

        let rad_grat = EMOTIONAL_RADIATION_STRENGTH * grat;
        let rad_grief = EMOTIONAL_RADIATION_STRENGTH * grief;
        for (x, y) in &self.cells {
            field[*x][*y][CH_SIGNAL_GRATITUDE] = (field[*x][*y][CH_SIGNAL_GRATITUDE] + rad_grat).min(1.0);
            field[*x][*y][CH_SIGNAL_GRIEF] = (field[*x][*y][CH_SIGNAL_GRIEF] + rad_grief).min(1.0);
        }

        self.generate_goals(field);
        self.update_intent();
        self.apply_intent_actions(field);
        self.update_phase(field);
        self.update_semantic_state(field);

        if self.age < 30 {
            self.protection_level = 1.0;
        } else if self.age < 45 {
            self.protection_level = 1.0 - (self.age - 30) as f64 / 15.0;
        } else {
            self.protection_level = 0.0;
        }

        self.pred_error = (self.pred_error * METRIC_DECAY).max(MIN_ACTIVE);
        self.self_surprise = (self.self_surprise * METRIC_DECAY).max(MIN_ACTIVE);
        self.cognitive_tension = (self.cognitive_tension * METRIC_DECAY).max(MIN_ACTIVE);
    }

    fn should_die(&self) -> bool {
        if self.cells.is_empty() { return true; }
        if self.pred_error > PRED_ERROR_THRESHOLD {
            if self.given_trigger && phi_hash(self.id as i64, self.age as i64) < 0.15 { return false; }
            if self.coherence > 0.8 && phi_hash(self.id as i64, self.age as i64) < 0.3 { return false; }
            if phi_hash(self.id as i64, self.age as i64) < 0.3 { return true; }
        }
        if self.protection_level > 0.2 {
            let death_prob = 0.1 * (1.0 - self.protection_level);
            if phi_hash(self.id as i64, self.age as i64, 777) < death_prob { return true; }
            return false;
        }
        if self.soul_weight < 0.1 { return true; }
        if self.unresolved_contradiction < 0.01 { return true; }
        if self.cells.len() < 2 && self.age > 5 { return true; }
        if self.age > 120 && self.energy < 0.05 { return true; }
        false
    }

    fn metabolic_tax(&self, field: &mut FieldLayer, hunger_mult: f64) -> f64 {
        let efficiency = 1.0 / (1.0 + self.pred_error);
        let mut cost = self.genome.metabolic_cost * self.cells.len() as f64 * (2.0 - efficiency) * hunger_mult;
        if *self.emotional_memory.get("grief").unwrap_or(&0.0) > EMOTIONAL_GRIEF_THRESHOLD {
            cost *= 1.0 + GRIEF_METABOLIC_PENALTY * (self.emotional_memory.get("grief").unwrap_or(&0.0) - EMOTIONAL_GRIEF_THRESHOLD);
        }
        for (x, y) in &self.cells {
            let take = field[*x][*y][CH_ENERGY].max(0.0).min(cost / self.cells.len() as f64);
            field[*x][*y][CH_ENERGY] -= take;
            cost -= take;
        }
        cost
    }

    fn can_divide(&self) -> bool {
        self.pred_error < DIVIDE_ERROR_THRESHOLD && self.energy > PATTERN_ENERGY_THRESHOLD
            && self.cells.len() >= DIVIDE_MIN_SIZE && self.alive && self.soul_weight > 0.2 && !self.in_dream
    }

    fn divide(&mut self, field: &FieldLayer, next_id: u32) -> Option<Pattern> {
        let mut xs: Vec<usize> = self.cells.iter().map(|(x, _)| *x).collect();
        xs.sort();
        let median_x = xs[xs.len() / 2];
        let child1_cells: HashSet<(usize, usize)> = self.cells.iter().filter(|(x, _)| *x < median_x).cloned().collect();
        let child2_cells: HashSet<(usize, usize)> = self.cells.iter().filter(|(x, _)| *x >= median_x).cloned().collect();
        if child1_cells.len() < 3 || child2_cells.len() < 3 { return None; }
        self.cells = child1_cells;
        let mut child = Pattern::new(next_id, child2_cells, Some(self));
        for i in 0..5 {
            child.belief[i] += 0.02 * (phi_hash(next_id as i64, i as i64, 200) - 0.5);
        }
        Some(child)
    }

    fn compete(&mut self, other: &mut Pattern, field: &mut FieldLayer) {
        if self.protection_level > 0.5 || other.protection_level > 0.5 { return; }
        let overlap: HashSet<(usize, usize)> = self.cells.intersection(&other.cells).cloned().collect();
        if overlap.is_empty() { return; }

        let mut sum_unk = 0.0;
        for x in 0..WORLD_SIZE { for y in 0..WORLD_SIZE { sum_unk += field[x][y][CH_UNKNOWN]; } }
        let avg_unk = sum_unk / (WORLD_SIZE * WORLD_SIZE) as f64;

        let mut my_power = self.fitness * self.energy.max(0.0);
        let mut other_power = other.fitness * other.energy.max(0.0);

        if self.role == 1 {
            my_power *= 1.0 + avg_unk;
        } else {
            let bonus = 1.0 + (0.2f64 - avg_unk).max(0.0) * 0.8;
            my_power *= bonus * if self.local_phase == "MODEL" { 1.1 } else { 1.0 };
        }
        if other.role == 1 {
            other_power *= 1.0 + avg_unk;
        } else {
            let bonus = 1.0 + (0.2f64 - avg_unk).max(0.0) * 0.8;
            other_power *= bonus * if other.local_phase == "MODEL" { 1.1 } else { 1.0 };
        }

        let grat_self = *self.emotional_memory.get("gratitude").unwrap_or(&0.0);
        if grat_self > EMOTIONAL_GRATITUDE_THRESHOLD {
            my_power *= 1.0 - GRATITUDE_AGGRESSION_REDUCTION * (grat_self - EMOTIONAL_GRATITUDE_THRESHOLD);
        }
        let grat_other = *other.emotional_memory.get("gratitude").unwrap_or(&0.0);
        if grat_other > EMOTIONAL_GRATITUDE_THRESHOLD {
            other_power *= 1.0 - GRATITUDE_AGGRESSION_REDUCTION * (grat_other - EMOTIONAL_GRATITUDE_THRESHOLD);
        }

        let winner_id = if my_power > other_power { self.id } else { other.id };

        for cell in &overlap {
            if phi_hash(cell.0 as i64, cell.1 as i64, self.id as i64) < 0.5 {
                if winner_id == self.id {
                    other.cells.remove(cell);
                    self.cells.insert(*cell);
                } else {
                    self.cells.remove(cell);
                    other.cells.insert(*cell);
                }
                field[cell.0][cell.1][CH_OWNER] = winner_id as f64;
            }
        }
    }
}

