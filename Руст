// MAIN LOOP
// =========================
fn run_simulation(steps: usize) {
    let mut field = init_field();
    let mut scar = init_scar();
    let mut echo_prison = EchoPrison::new();
    let mut patterns: Vec<Pattern> = Vec::new();
    let mut last_rescue_t: i64 = -100;

    NEXT_PATTERN_ID.set(1);

    for i in 0..MIN_PATTERNS_GUARANTEED {
        let seed = (phi_hash(0, i as i64, 12345) * WORLD_SIZE as f64 * WORLD_SIZE as f64) as usize;
        let x = seed % WORLD_SIZE;
        let y = (seed / WORLD_SIZE) % WORLD_SIZE;
        field[x][y][CH_ENERGY] += 0.3;
        let id = next_id();
        let mut cells = HashSet::new();
        cells.insert((x, y));
        let mut p = Pattern::new(id, cells, None);
        p.update_properties(&field);
        patterns.push(p);
    }

    for t in 0..steps as i64 {
        field_dynamics(&mut field, &mut scar, t);
        crisis_injection(&mut field, t);
        anti_conformist_injection(&mut patterns, t);

        let mut given_counter = 0usize;

        for i in 0..patterns.len() {
            if !patterns[i].alive { continue; }
            patterns[i].update_model(&mut field, None, Some(&mut given_counter), &scar);

            if patterns[i].pred_error <= PRED_ERROR_THRESHOLD {
                let mut new_cells = HashSet::new();
                for (x, y) in &patterns[i].cells {
                    let intent_bias = if let Some(intent) = &patterns[i].intent {
                        if intent.goal_type == "explore" { 1.5 } else { 1.0 }
                    } else { 1.0 };

                    for (dx, dy) in &[(-1i32, 0i32), (1, 0), (0, -1), (0, 1)] {
                        let nx = ((*x as i32 + dx + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                        let ny = ((*y as i32 + dy + WORLD_SIZE as i32) % WORLD_SIZE as i32) as usize;
                        if field[nx][ny][CH_OWNER] < 0.5 {
                            let strategy = patterns[i].genome.epistemic_strategy;
                            let base_threshold = patterns[i].pred_error * (1.5 + if patterns[i].given_trigger { 1.0 } else { 0.0 });
                            let threshold = if strategy > 0.66 {
                                base_threshold / (1.0 + field[nx][ny][CH_UNKNOWN].min(0.8))
                            } else if strategy >= 0.33 {
                                base_threshold * (1.0 + (field[nx][ny][CH_UNKNOWN].min(0.8) - patterns[i].unknown_prediction).max(0.0))
                            } else {
                                base_threshold
                            };
                            if field[nx][ny][CH_SURPRISE] < threshold / intent_bias {
                                new_cells.insert((nx, ny));
                            }
                        }
                    }
                }
                for (nx, ny) in new_cells {
                    if phi_hash(nx as i64, ny as i64, patterns[i].id as i64) < 0.3 {
                        patterns[i].cells.insert((nx, ny));
                        field[nx][ny][CH_OWNER] = patterns[i].id as f64;
                    }
                }
            }
        }

        resolve_competitions_spatial(&mut patterns, &mut field);

        for i in 0..patterns.len() {
            if patterns[i].alive {
                patterns[i].metabolic_tax(&mut field, HUNGER_MULTIPLIER);
                if patterns[i].should_die() {
                    echo_prison.store_echo(&patterns[i]);
                    patterns[i].alive = false;
                }
            }
        }

        let mut new_patterns = Vec::new();
        for i in 0..patterns.len() {
            if patterns[i].alive && patterns[i].can_divide() {
                let id = next_id();
                if let Some(child) = patterns[i].divide(&field, id) {
                    new_patterns.push(child);
                }
            }
        }
        patterns.extend(new_patterns);

        let spore_children = process_spores(&mut patterns, &field);
        patterns.extend(spore_children);

        echo_prison.inject_echo(&patterns, &mut field, t);
        emergency_rescue(&mut patterns, &mut field, t, &mut last_rescue_t);

        patterns.retain(|p| p.alive);
        for p in &mut patterns { p.age += 1; }

        if t >= 50 && t % 10 == 0 {
            let components = detect_new_components(&field);
            if !components.is_empty() {
                match_patterns(components, &mut patterns, &mut field);
            }
        }

        if t % 100 == 0 {
            println!("{}", collect_metrics(&patterns, &field, t));
        }
    }

    println!("\n=== FINAL REPORT ===");
    let alive: Vec<&Pattern> = patterns.iter().filter(|p| p.alive).collect();
    println!("Surviving patterns: {}", alive.len());
    let lineages: HashSet<u32> = alive.iter().map(|p| p.lineage_id).collect();
    println!("Lineage diversity: {}", lineages.len());

    let long_lived: Vec<&Pattern> = alive.iter().filter(|p| p.age > 100).collect();
    println!("Long-lived patterns (>100 steps): {}", long_lived.len());

    let mut sorted: Vec<&Pattern> = patterns.iter().filter(|p| !p.biography.is_empty()).collect();
    sorted.sort_by(|a, b| b.age.cmp(&a.age));
    println!("\n--- Top 5 Longest-Lived Patterns ---");
    for p in sorted.iter().take(5) {
        println!("  Pattern #{} (age={}, soul={:.2f}, cells={})",
            p.id, p.age, p.soul_weight, p.cells.len());
        println!("  Lineage: {}, Role: {}, Phase: {}", p.lineage_id, p.role, p.local_phase);
        println!("  Emotional: grat={:.2f} grief={:.2f}",
            p.emotional_memory.get("gratitude").unwrap_or(&0.0),
            p.emotional_memory.get("grief").unwrap_or(&0.0));
        println!("  Semantic state: {}", p.semantic_state);
    }
}

