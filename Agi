def diffuse(field):
    field = np.nan_to_num(field, nan=0.0)
    for ch in [CH['energy'], CH['flux'], CH['scar'], CH['noise'], CH['vorticity'], CH['resonance']]:
        plane = field[:,:,ch]
        neighbors = (np.roll(plane, 1, axis=0) + np.roll(plane, -1, axis=0) +
                     np.roll(plane, 1, axis=1) + np.roll(plane, -1, axis=1))
        field[:,:,ch] = plane * 0.8 + neighbors * 0.05
    field[:,:,CH['energy']] *= GLOBAL_VISCOSITY; field[:,:,CH['vorticity']] *= VORTICITY_DECAY
    return field

def update_scar(field, scar):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    delta = energy - np.mean(energy)
    scar = scar + 0.05 * np.tanh(np.abs(delta))
    return np.clip(scar, 0, SCAR_SATURATION)

def apply_scar_feedback(field, scar):
    field[:,:,CH['energy']] += SCAR_ENERGY_COUPLING * np.tanh(np.nan_to_num(scar, nan=0.0))
    field[:,:,CH['energy']] -= LOCAL_FATIGUE * field[:,:,CH['energy']] * np.abs(np.nan_to_num(scar, nan=0.0))
    field[:,:,CH['energy']] *= 0.999
    field[:,:,CH['vorticity']] += 0.001 * (np.nan_to_num(scar, nan=0.0) - np.mean(np.nan_to_num(scar, nan=0.0)))
    return field

def heartbeat_injection(field, t):
    raw = (t * PHI * HEARTBEAT_FREQ) % 1.0
    cx = int(raw * (WORLD_SIZE-1)); cy = int(((raw * PHI) % 1.0) * (WORLD_SIZE-1))
    for dx in [-1, 0, 1]:
        for dy in [-1, 0, 1]:
            nx, ny = (cx+dx)%WORLD_SIZE, (cy+dy)%WORLD_SIZE
            field[nx, ny, CH['energy']] += HEARTBEAT_AMPLITUDE * (1 - 0.3*(abs(dx)+abs(dy)))
    return field

def apply_crisis(field, t):
    if t % CRISIS_PERIOD == 0 and t > 0:
        shock = np.fromfunction(lambda x, y: phi_noise(t+5000, x, y), (WORLD_SIZE, WORLD_SIZE))
        field[:,:,CH['energy']] += CRISIS_INTENSITY * shock
    return field

def calculate_boredom(patterns, field):
    if len(patterns) == 0: return 0.5
    avg_err = safe_mean([p.pred_error for p in patterns], MIN_ACTIVE)
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.05)
    avg_tension = safe_mean([p.cognitive_tension for p in patterns], MIN_ACTIVE)
    avg_err = max(avg_err, MIN_ACTIVE); avg_tension = max(avg_tension, MIN_ACTIVE)
    boredom = 1.0 - (squash(avg_err) + squash(avg_tension) + squash(avg_unknown)) / 3.0
    return np.clip(boredom, 0.0, 1.0)

