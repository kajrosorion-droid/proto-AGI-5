        self.emotional_memory['gratitude'] = (EMOTIONAL_MEMORY_DECAY * self.emotional_memory['gratitude'] +
                                              (1 - EMOTIONAL_MEMORY_DECAY) * local_gratitude)
        self.emotional_memory['grief'] = (EMOTIONAL_MEMORY_DECAY * self.emotional_memory['grief'] +
                                          (1 - EMOTIONAL_MEMORY_DECAY) * local_grief)

        neighbor_gratitude = 0.0; neighbor_grief = 0.0; neighbor_count = 0
        for (x, y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != self.id:
                    neighbor_gratitude += field[nx, ny, CH['signal_gratitude']]
                    neighbor_grief += field[nx, ny, CH['signal_grief']]
                    neighbor_count += 1
        if neighbor_count > 0:
            neighbor_gratitude /= neighbor_count; neighbor_grief /= neighbor_count
            emotional_divergence = (abs(self.emotional_memory['gratitude'] - neighbor_gratitude) +
                                    abs(self.emotional_memory['grief'] - neighbor_grief))
            step = self.age
            if (self.age >= SPEACIATION_MIN_AGE and
                emotional_divergence > EMOTIONAL_SPECIATION_THRESHOLD and 
                phi_hash(self.id, step, 888) < EMOTIONAL_SPECIATION_PROB and
                (step - self.last_speciation_age) > SPEACIATION_COOLDOWN):
                old_lineage = self.lineage_id
                self.lineage_id = self.id + 1_000_000
                self.last_speciation_age = step
                self._log_event("speciation", old_lineage=old_lineage, new_lineage=self.lineage_id)
                print(f"[t={step}] EMOTIONAL SPECIATION: Pattern {self.id} lineage {old_lineage} → {self.lineage_id}")
            self.emotional_memory['gratitude'] = (EMOTIONAL_INDIVIDUALITY * self.emotional_memory['gratitude'] +
                                                  (1 - EMOTIONAL_INDIVIDUALITY) * neighbor_gratitude)
            self.emotional_memory['grief'] = (EMOTIONAL_INDIVIDUALITY * self.emotional_memory['grief'] +
                                              (1 - EMOTIONAL_INDIVIDUALITY) * neighbor_grief)
        self.emotional_memory['gratitude'] = np.clip(self.emotional_memory['gratitude'], 0.0, 1.0)
        self.emotional_memory['grief'] = np.clip(self.emotional_memory['grief'], 0.0, 1.0)

        self.crisis_memory = min(CRISIS_MEMORY_DECAY * self.crisis_memory + (1 - CRISIS_MEMORY_DECAY) * avg_crisis_mem, CRISIS_MEMORY_MAX)
        self.spirit_gap = float(np.mean(np.abs(avg_real - self.prediction)))
        self.epistemic_load = avg_unknown

        if avg_crisis_mem > 0.5:
            self.semantic_memory['events'].append({
                'type': 'crisis', 't': self.age,
                'location': list(self.cells)[0] if self.cells else (0,0),
                'intensity': avg_crisis_mem
            })
            if len(self.semantic_memory['events']) > 5: self.semantic_memory['events'].pop(0)
        for event in self.semantic_memory['events']:
            event['recency'] = np.exp(-(self.age - event['t']) / 50.0)

        error = np.clip(avg_real - self.prediction, -10, 10); current_error = np.clip(np.mean(error**2), 0, 1e6)
        raw_pred_error = 0.9 * self.pred_error + 0.1 * current_error + 0.05 * self.self_surprise
        noise_val = (phi_hash(self.id, self.age + 500, 500) - 0.5) * BASE_NOISE * 2.0
        self.pred_error = squash(raw_pred_error) + noise_val
        self.pred_error = np.clip(self.pred_error, MIN_ACTIVE, MAX_METRIC)
        if np.isnan(self.pred_error): self.pred_error = MIN_ACTIVE
        if self.pred_error < 0.05 and phi_hash(self.id, self.age) < 0.1:
            self.apply_given_operator(field, forced=True)

        true_surprise = np.abs(error); adaptive_surprise = true_surprise * (1.0 + self.self_consistency)
        self.surprise_signal = squash(float(np.mean(adaptive_surprise)))
        unknown_error = avg_unknown - self.unknown_prediction
        self.unknown_error = 0.9 * self.unknown_error + 0.1 * np.clip(unknown_error**2, 0, 100)
        self.belief = np.clip(self.belief + 0.05 * error + 0.05 * adaptive_surprise, -10, 10)
        self.prediction = np.clip(self.belief + self.model, -10, 10)
        self.model = np.clip(self.model + self.genome['learning_rate'] * (error + 2.0 * adaptive_surprise), -10, 10)
        self.unknown_belief += 0.05 * unknown_error
        self.unknown_prediction = self.unknown_belief + self.unknown_model
        self.unknown_model += self.genome['meta_learning_rate'] * unknown_error
        self.self_consistency = float(np.linalg.norm(self.prediction - self.belief))
        if np.isnan(self.self_consistency): self.self_consistency = 0.5
        self.coherence = 1.0 / (1.0 + self.self_consistency)
        self.confidence = squash(1.0 / (1.0 + self.pred_error))

        if self.coherence > ANTI_COHERENCE_THRESHOLD and phi_hash(self.id, self.age, 9999) < 0.1:
            shake = np.array([phi_hash(self.id, self.age, 8888+i) - 0.5 for i in range(5)]) * ANTI_COHERENCE_SHAKE
            self.belief += shake
        self.model += np.array([phi_hash(self.id, i, self.age + 1000) - 0.5 for i in range(5)]) * 0.002
        self.model = np.clip(self.model, -10, 10)

        if self.given_cooldown > 0: self.given_cooldown -= 1; self.given_trigger = False
        else:
            adaptive_consistency_threshold = GIVEN_CONSISTENCY_THRESHOLD
            if self.confidence > COMPLACENCY_CONFIDENCE and self.cognitive_tension < COMPLACENCY_TENSION:
                adaptive_consistency_threshold *= COMPLACENCY_THRESHOLD_SCALE
            consistency_ok = (self.self_consistency < adaptive_consistency_threshold * 2.5 or self.pred_error < 0.01)
            if self.age >= GIVEN_MIN_AGE and self.confidence > GIVEN_CONFIDENCE_THRESHOLD and consistency_ok:
                self.apply_given_operator(field)
            else: self.given_trigger = False

        raw_tension = self.pred_error + 0.1 * self.self_surprise + 0.1 * self.self_consistency
        noise_tension = (phi_hash(self.id, self.age + 700, 700) - 0.5) * BASE_NOISE * 2.0
        self.cognitive_tension = squash(raw_tension) + noise_tension
        self.cognitive_tension = np.clip(self.cognitive_tension, MIN_ACTIVE, MAX_METRIC)
        if np.isnan(self.cognitive_tension): self.cognitive_tension = MIN_ACTIVE

        self.soul_weight += 0.006 * (self.spirit_gap + self.pred_error + avg_binding)
        self.soul_weight -= 0.003 * (1.0 - self.unresolved_contradiction)
        if self.local_phase == "CRISIS": self.soul_weight += 0.01 * self.crisis_memory
        for (cx, cy) in self.cells:
            whisper = 0.0
            for ch in range(CH['signal_alarm'], CH['signal_grief']+1): whisper += field[cx, cy, ch]
            if whisper > 0.01:
                self.soul_weight += OPERATOR_SOUL_WHISPER * whisper
                break
        self.soul_weight += GRIEF_SOUL_IMPACT * local_grief
        self.soul_momentum = 0.95 * self.soul_momentum + 0.05 * (0.65 - self.soul_weight)
        self.soul_weight += 0.001 * self.soul_momentum
        self.soul_weight = np.clip(self.soul_weight, 0.0, 1.0)

        self.unresolved_contradiction += 0.01 * avg_binding + 0.005 * self.body_memory
        self.unresolved_contradiction -= 0.003 * (1.0 - self.cognitive_tension)
        self.unresolved_contradiction = np.clip(self.unresolved_contradiction, 0.0, 1.0)
        self.body_memory = 0.99 * self.body_memory + 0.01 * self.pred_error

        base_lr = MODEL_LEARNING_RATE * (0.8 + 0.4 * phi_hash(self.id, 1, 3))
        target_lr = base_lr * (1.0 + 0.1 * avg_binding)
        self.genome['learning_rate'] = 0.95 * self.genome['learning_rate'] + 0.05 * np.clip(target_lr, 0.05, 0.2)

        self.fitness = (1.0 / (1.0 + self.pred_error) + 0.5 * max(0, -self.error_trend) +
                        0.1 * self.compression + 0.2 * self.coherence -
                        0.3 * max(0, (0.05 - self.unresolved_contradiction)) - 0.1 * self.body_memory)
        self.fitness *= (1.0 + GRATITUDE_COOPERATION_BONUS * local_gratitude)

        if lineage_counts is not None and len(lineage_counts) > 1:
            my_count = lineage_counts.get(self.lineage_id, 1)
            total = sum(lineage_counts.values())
            rarity = 1.0 - (my_count / total)
            self.fitness += LINEAGE_RARITY_BOOST * rarity

        if (self.crisis_memory > SCREAM_CRISIS_THRESHOLD and 
            self.soul_weight < SCREAM_SOUL_THRESHOLD and
            phi_hash(self.id, self.age, 111) < SCREAM_PROB):
            self.apply_scream(field)

        rad_grat = EMOTIONAL_RADIATION_STRENGTH * self.emotional_memory['gratitude']
        rad_grief = EMOTIONAL_RADIATION_STRENGTH * self.emotional_memory['grief']
        for (x, y) in self.cells:
            field[x, y, CH['signal_gratitude']] = min(1.0, field[x, y, CH['signal_gratitude']] + rad_grat)
            field[x, y, CH['signal_grief']] = min(1.0, field[x, y, CH['signal_grief']] + rad_grief)
            if self.emotional_memory['gratitude'] > 0.3:
                field[x, y, CH['signal_invitation']] = min(1.0, field[x, y, CH['signal_invitation']] + rad_grat * 0.5)
            if self.in_scream:
                field[x, y, CH['signal_alarm']] = min(1.0, field[x, y, CH['signal_alarm']] + 0.2)
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                field[nx, ny, CH['signal_gratitude']] = min(1.0, field[nx, ny, CH['signal_gratitude']] + rad_grat)
                field[nx, ny, CH['signal_grief']] = min(1.0, field[nx, ny, CH['signal_grief']] + rad_grief)
                if self.emotional_memory['gratitude'] > 0.3:
                    field[nx, ny, CH['signal_invitation']] = min(1.0, field[nx, ny, CH['signal_invitation']] + rad_grat * 0.5)
                if self.in_scream:
                    field[nx, ny, CH['signal_alarm']] = min(1.0, field[nx, ny, CH['signal_alarm']] + 0.2)

        for (x, y) in self.cells:
            grat = self.emotional_memory['gratitude']; grief = self.emotional_memory['grief']
            warn = field[x, y, CH['signal_warning']]; inv = field[x, y, CH['signal_invitation']]
            alarm = field[x, y, CH['signal_alarm']]; curios = field[x, y, CH['signal_curiosity']]

            if self.in_dream:
                self.semantic_state = "dreaming"
            elif grat > 0.25 and warn > 0.10:
                self.semantic_state = "grateful_but_cautious"
            elif grief > 0.25 and inv > 0.10:
                self.semantic_state = "seeking_comfort"
            elif alarm > 0.25 and curios > 0.10:
                self.semantic_state = "exploring_danger"
            elif grat > 0.25 and self.cognitive_tension < 0.15:
                self.semantic_state = "contentment"
            elif self.in_scream:
                self.semantic_state = "screaming"
            else:
                self.semantic_state = "neutral"

        for (x, y) in self.cells:
            if self.emotional_memory['gratitude'] > 0.5:
                field[x, y, CH['intent_cooperate']] = min(1.0, field[x, y, CH['intent_cooperate']] + 0.3)
            elif self.emotional_memory['grief'] > 0.5:
                field[x, y, CH['intent_seek_help']] = min(1.0, field[x, y, CH['intent_seek_help']] + 0.3)
            elif local_gratitude > 0.3:
                field[x, y, CH['intent_explore']] = min(1.0, field[x, y, CH['intent_explore']] + 0.2)

        # cognitive modules
        observed = np.array([
            avg_real[0], avg_unknown, avg_binding, avg_crisis_mem,
            local_gratitude, local_grief, len(self.cells)/100.0, self.energy
        ])
        self.update_world_model(observed)
        self.generate_goals(field)
        self.update_intent()
        self.form_concepts()
        self.apply_intent_actions(field)
        self.update_resonance(field)

        self.update_phase(field)
        self.pred_error = max(self.pred_error * METRIC_DECAY, MIN_ACTIVE)
        self.self_surprise = max(self.self_surprise * METRIC_DECAY, MIN_ACTIVE)
        self.cognitive_tension = max(self.cognitive_tension * METRIC_DECAY, MIN_ACTIVE)

    def apply_scream(self, field):
        if not self.in_scream:
            self._log_event("scream_enter", soul=round(self.soul_weight, 3))
            self.in_scream = True
            self.soul_weight = max(0.05, self.soul_weight - 0.2)
            self.unresolved_contradiction = min(1.0, self.unresolved_contradiction + 0.3)
            self.crisis_memory = min(CRISIS_MEMORY_MAX, self.crisis_memory + 0.15)
            for (x, y) in self.cells:
                field[x, y, CH['scar']] = min(1.0, field[x, y, CH['scar']] + SCREAM_SCAR_IMPACT)
                field[x, y, CH['binding']] = min(1.0, field[x, y, CH['binding']] + SCREAM_BINDING_BOOST)
                field[x, y, CH['energy']] = max(-0.2, field[x, y, CH['energy']] - SCREAM_ENERGY_PENALTY)
                field[x, y, CH['crisis']] = min(1.0, field[x, y, CH['crisis']] + 0.3)
            for (x, y) in self.cells:
                for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                    nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                    field[nx, ny, CH['signal_alarm']] = min(1.0, field[nx, ny, CH['signal_alarm']] + 0.5)

    def update_properties(self, field):
        if not self.cells: self.alive = False; return
        self.energy = safe_mean([field[x, y, CH['energy']] for (x, y) in self.cells], 0.1)
        self.vorticity = safe_mean([field[x, y, CH['vorticity']] for (x, y) in self.cells], 0.0)

    def metabolic_tax(self, field, hunger_mult=1.0):
        efficiency = 1.0 / (1.0 + self.pred_error)
        cost = self.genome['metabolic_cost'] * len(self.cells) * (2.0 - efficiency) * hunger_mult
        if self.emotional_memory['grief'] > EMOTIONAL_GRIEF_THRESHOLD:
            cost *= (1.0 + GRIEF_METABOLIC_PENALTY * (self.emotional_memory['grief'] - EMOTIONAL_GRIEF_THRESHOLD))
        for (x, y) in self.cells:
            take = min(max(field[x, y, CH['energy']], 0), cost / max(1, len(self.cells)))
            field[x, y, CH['energy']] -= take; cost -= take
        return cost

    def grow(self, field):
        if not self.alive or self.pred_error > PRED_ERROR_THRESHOLD or self.in_dream: return
        intent_bias = 1.0
        if self.intent and self.intent["type"] == "explore":
            intent_bias = 1.5
        new_cells = set()
        center_x, center_y = WORLD_SIZE / 2.0, WORLD_SIZE / 2.0
        max_dist = np.sqrt(center_x**2 + center_y**2)
        for (x, y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                if field[nx, ny, CH['owner']] == 0:
                    strategy = self.genome['epistemic_strategy']
                    base_threshold = self.pred_error * (1.5 + 1.0 * self.given_trigger)
                    if strategy > 0.66: base_threshold /= (1.0 + np.clip(field[nx, ny, CH['unknown']], 0, 0.8))
                    elif strategy >= 0.33: base_threshold *= (1.0 + max(0, np.clip(field[nx, ny, CH['unknown']], 0, 0.8) - self.unknown_prediction))
                    center_bonus = 0.0
                    dist_to_center = np.sqrt((nx - center_x)**2 + (ny - center_y)**2)
                    if self.unresolved_contradiction > 0.3:
                        center_bonus = 0.60 * (1.0 - dist_to_center / max_dist) * self.unresolved_contradiction
                    elif self.unresolved_contradiction < 0.15:
                        center_bonus = -0.15 * (1.0 - dist_to_center / max_dist)
                    if field[nx, ny, CH['surprise']] < base_threshold / intent_bias:
                        new_cells.add((nx, ny))
        for cell in new_cells:
            dist = np.sqrt((cell[0] - center_x)**2 + (cell[1] - center_y)**2)
            threshold = 0.3
            if self.unresolved_contradiction > 0.3:
                threshold += 0.60 * (1.0 - dist / max_dist) * self.unresolved_contradiction
            elif self.unresolved_contradiction < 0.15: threshold += 0.15 * (dist / max_dist)
            if phi_hash(cell[0], cell[1], self.id) < threshold:
                self.cells.add(cell); field[cell[0], cell[1], CH['owner']] = self.id

    def can_divide(self):
        return (self.pred_error < DIVIDE_ERROR_THRESHOLD and self.energy > PATTERN_ENERGY_THRESHOLD and
                len(self.cells) >= DIVIDE_MIN_SIZE and self.alive and self.soul_weight > 0.2 and not self.in_dream)

    def divide(self, field, next_id):
        cells_list = list(self.cells); xs = [c[0] for c in cells_list]; median_x = np.median(xs)
        child1_cells = {c for c in cells_list if c[0] < median_x}
        child2_cells = {c for c in cells_list if c[0] >= median_x}
        if len(child1_cells) < 3 or len(child2_cells) < 3: return None
        self.cells = child1_cells
        child = Pattern(next_id, child2_cells, parent=self)
        child._log_event("born_from_division", parent_id=self.id)
        noise = 0.02 * np.array([phi_hash(next_id, i, 200) - 0.5 for i in range(5)])
        child.belief = self.belief + noise
        child.unknown_belief = self.unknown_belief + 0.02 * (phi_hash(next_id, 99, 200) - 0.5)
        child.self_model = self.self_model + 0.02 * (np.array([phi_hash(next_id, 201, 200) - 0.5,
                                                                phi_hash(next_id, 202, 200) - 0.5]))
        child.emotional_memory['gratitude'] += (phi_hash(next_id, 0, 300) - 0.5) * EMOTIONAL_MUTATION_STRENGTH
        child.emotional_memory['grief'] += (phi_hash(next_id, 1, 301) - 0.5) * EMOTIONAL_MUTATION_STRENGTH
        child.update_properties(field); child.update_model(field)
        self.update_properties(field); self.update_model(field)
        return child

    def compete(self, other, field):
        overlap = self.cells & other.cells
        if not overlap: return
        my_power = self.fitness * max(self.energy, 0); other_power = other.fitness * max(other.energy, 0)
        avg_unk = safe_mean(field[:,:,CH['unknown']], 0.05)
        if self.role == 1: my_power *= 1.0 + avg_unk
        else: bonus = 1.0 + max(0, (0.2 - avg_unk)) * 0.8; my_power *= bonus * (1.1 if self.local_phase == "MODEL" else 1.0)
        if other.role == 1: other_power *= 1.0 + avg_unk
        else: bonus = 1.0 + max(0, (0.2 - avg_unk)) * 0.8; other_power *= bonus * (1.1 if other.local_phase == "MODEL" else 1.0)
        if self.emotional_memory['gratitude'] > EMOTIONAL_GRATITUDE_THRESHOLD:
            my_power *= (1.0 - GRATITUDE_AGGRESSION_REDUCTION * (self.emotional_memory['gratitude'] - EMOTIONAL_GRATITUDE_THRESHOLD))
        if other.emotional_memory['gratitude'] > EMOTIONAL_GRATITUDE_THRESHOLD:
            other_power *= (1.0 - GRATITUDE_AGGRESSION_REDUCTION * (other.emotional_memory['gratitude'] - EMOTIONAL_GRATITUDE_THRESHOLD))
        if not np.isfinite(my_power): my_power = 0
        if not np.isfinite(other_power): other_power = 0
        winner, loser = (self, other) if my_power > other_power else (other, self)
        cells_lost = 0
        for cell in overlap.copy():
            if phi_hash(cell[0], cell[1], self.id) < 0.5:
                loser.cells.discard(cell); winner.cells.add(cell)
                field[cell[0], cell[1], CH['owner']] = winner.id
                winner.soul_weight += 0.01; loser.soul_weight -= 0.02
                cells_lost += 1
            elif (loser.unresolved_contradiction > 0.2 and phi_hash(cell[0], cell[1], self.id + 999) < 0.2) or \
                 phi_hash(cell[0], cell[1], self.id + 777) < 0.05:
                winner.cells.discard(cell); loser.cells.add(cell)
                field[cell[0], cell[1], CH['owner']] = loser.id
                winner.soul_weight -= 0.01; loser.soul_weight += 0.03
        if cells_lost > 0 and loser.alive:
            loser._log_event("lost_cells_in_competition", lost=cells_lost, opponent=winner.id)

    def should_die(self):
        if self.soul_weight < 0.1: self._log_event("death_soul_lost"); return True
        if self.unresolved_contradiction < 0.01: self._log_event("death_no_contradiction"); return True
        if self.given_trigger and phi_hash(self.id, self.age) < 0.15: return False
        if self.pred_error > PRED_ERROR_THRESHOLD:
            if self.coherence > 0.8 and phi_hash(self.id, self.age) < 0.3: return False
            if phi_hash(self.id, self.age) < 0.3: self._log_event("death_high_error"); return True
            return False
        if len(self.cells) < 2 and self.age > 5: self._log_event("death_starvation"); return True
        if self.age > 120 and self.energy < 0.05: self._log_event("death_old_age"); return True
        return False

