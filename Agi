            old_intent = self.intent["type"] if self.intent else "none"
            self.intent = best
            self.intent_commitment = best["priority"]
            self.intent_age = 0
            self._log_event("intent_switch", old=old_intent, new=self.intent["type"])
        else:
            self.intent_age += 1
        for g in self.goals:
            g['age'] += 1
