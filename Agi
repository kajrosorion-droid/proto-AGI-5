    if boredom_score > 0.4 and patterns:
        for p in patterns:
            if p.alive and phi_hash(p.id, t, 500) < 0.2: p.apply_given_operator(field, forced=True)

    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            if (np.isfinite(field[x, y, CH['unknown']]) and field[x, y, CH['unknown']] > UNKNOWN_SPAWN_THRESHOLD and
