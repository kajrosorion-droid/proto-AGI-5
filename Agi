def init_field():
    F = np.zeros((WORLD_SIZE, WORLD_SIZE, CHANNELS))
    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            F[x, y, CH['energy']] = phi_hash(x, y, 1) * 0.2 - 0.1
            F[x, y, CH['flux']] = phi_hash(x, y, 2) * 0.1
            F[x, y, CH['scar']] = 0.0; F[x, y, CH['noise']] = 0.0
            F[x, y, CH['vorticity']] = phi_hash(x, y, 3) * 0.1 - 0.05
            F[x, y, CH['owner']] = 0.0; F[x, y, CH['surprise']] = 0.0
            F[x, y, CH['unknown']] = UNKNOWN_BACKGROUND
            F[x, y, CH['event']] = 0.0; F[x, y, CH['btype']] = 0.0
            F[x, y, CH['crisis']] = 0.0; F[x, y, CH['binding']] = 0.05
            for ch in range(12, 23): F[x, y, ch] = 0.0
            F[x, y, CH['energy']] += phi_noise(0, x, y, seed=42) * 0.1
    return F

def init_scar(): return np.zeros((WORLD_SIZE, WORLD_SIZE))

def match_patterns(new_components, old_patterns, field):
    matched = set(); updated_patterns = []
    for cells in new_components:
        best_p = None; best_overlap = 0
        for p in old_patterns:
            if not p.alive or p.id in matched: continue
            overlap = len(cells & p.cells)
            if overlap > best_overlap: best_overlap = overlap; best_p = p
        if best_p and best_overlap > len(cells) * 0.3:
            best_p.cells = cells; best_p.update_properties(field); best_p.update_model(field)
            best_p.age += 1; updated_patterns.append(best_p); matched.add(best_p.id)
        else:
            pid = max([p.id for p in old_patterns] + [1000]) + 1
