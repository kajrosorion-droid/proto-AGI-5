    field[:,:,CH['crisis']] *= CRISIS_MEMORY_DECAY; field[:,:,CH['event']] *= 0.9; field[:,:,CH['btype']] *= 0.9
    field[:,:,CH['binding']] *= 0.975; field[:,:,CH['binding']] *= 0.99
