            p = Pattern(pid, {(x, y)}); p.lineage_id = pid; patterns.append(p)
    return next_id_counter

def _resolve_competitions(field, patterns):
    alive = [p for p in patterns if p.alive]
    for i, p1 in enumerate(alive):
        for p2 in alive[i+1:]:
            if p1.cells & p2.cells: p1.compete(p2, field)

def _apply_divisions(field, patterns, next_id_counter):
    newborns = []
    for p in patterns:
        if p.can_divide():
            child = p.divide(field, next_id_counter)
            if child: newborns.append(child); next_id_counter += 1
    patterns.extend(newborns)
    return next_id_counter

